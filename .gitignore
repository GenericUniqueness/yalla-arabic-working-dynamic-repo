scripts/pipeline/*.json
scripts/content/*.json

# Secrets / signing / Firebase config — never publish to GitHub
# (files remain on local disk so local builds keep working)
*.jks
*.keystore
android/key.properties
android/app/upload-keystore.jks
android/app/google-services.json
lib/firebase_options.dart
.env
.env.*
